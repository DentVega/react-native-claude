{
  "name": "[PROYECTO]",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "maestro test .maestro/flows",
    "e2e:smoke": "maestro test .maestro/flows/smoke.yaml",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "expo": "latest",
    "expo-router": "latest",
    "expo-localization": "latest",
    "expo-secure-store": "latest",
    "expo-constants": "latest",
    "expo-linking": "latest",
    "expo-status-bar": "latest",
    "expo-splash-screen": "latest",
    "expo-font": "latest",
    "react": "latest",
    "react-native": "latest",
    "react-native-safe-area-context": "latest",
    "react-native-screens": "latest",
    "react-native-gesture-handler": "latest",
    "react-native-reanimated": "latest",
    "react-native-svg": "latest",
    "@react-native-community/netinfo": "latest",
    "nativewind": "latest",
    "tailwindcss": "^3.4.0",
    "clsx": "latest",
    "tailwind-merge": "latest",
    "class-variance-authority": "latest",
    "zustand": "latest",
    "@tanstack/react-query": "latest",
    "react-hook-form": "latest",
    "zod": "latest",
    "@hookform/resolvers": "latest",
    "i18next": "latest",
    "react-i18next": "latest",
    "@react-native-async-storage/async-storage": "latest",
    "lucide-react-native": "latest"
  },
  "devDependencies": {
    "@babel/core": "latest",
    "@types/react": "latest",
    "typescript": "latest",
    "eslint": "^9",
    "eslint-config-expo": "latest",
    "eslint-config-prettier": "latest",
    "eslint-plugin-boundaries": "latest",
    "prettier": "latest",
    "babel-plugin-module-resolver": "latest",
    "react-native-svg-transformer": "latest",
    "jest": "latest",
    "jest-expo": "latest",
    "@react-native/jest-preset": "latest",
    "@testing-library/react-native": "latest",
    "@types/jest": "latest",
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "husky": "latest",
    "lint-staged": "latest",
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest"
  },
  "private": true
}
